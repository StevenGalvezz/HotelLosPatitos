@model IEnumerable<HotelLosPatitos.Domain.Entities.Habitacion>

@{
    ViewData["Title"] = "Habitaciones Disponibles";
}

<div class="container my-5">

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4 bg-dark text-white rounded-3">
                <h5 class="card-title mb-3 fw-bold"><i class="bi bi-search me-2 text-warning"></i>¿Ya tienes una reservación?</h5>
                <form asp-action="Buscar" method="get" class="row g-2">
                    <div class="col-sm-9">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-hash"></i></span>
                            <input type="number" name="idReservacion" class="form-control border-0" placeholder="Ingrese el número de su reservación (Ej: 1)" required />
                        </div>
                    </div>
                    <div class="col-sm-3 d-grid">
                        <button type="submit" class="btn btn-warning fw-semibold shadow-sm">Buscar Reserva</button>
                    </div>
                </form>

                @if (TempData["MensajeError"] != null)
                {
                    <div class="alert alert-danger-custom mt-3 mb-0 p-2 text-warning bg-transparent border-0 fs-7" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold text-dark mb-2">Nuestras Habitaciones Disponibles</h2>
        <p class="text-muted fs-5">Seleccione la opción ideal para su descanso y realice su reserva de forma inmediata.</p>
        <hr class="mx-auto text-primary opacity-25" style="width: 100px; height: 3px;">
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="card p-5 border-0 shadow-sm bg-white rounded-3">
                    <i class="bi bi-house-x display-3 text-muted mb-3"></i>
                    <h4 class="text-dark fw-bold">No hay disponibilidad en este momento</h4>
                    <p class="text-muted mb-0">Estimado usuario, actualmente no poseemos habitaciones activas para reservar. Por favor, consulte más tarde.</p>
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden position-relative card-habitacion bg-white">

                        <div class="position-absolute top-0 end-0 m-3 z-1">
                            @switch (item.TipoDeHabitacion)
                            {
                                case 1:
                                    <span class="badge bg-secondary px-3 py-2 shadow-sm fs-7">Junior</span>
                                    ; break;
                                case 2:

                                    <span class="badge bg-info text-dark px-3 py-2 shadow-sm fs-7 fw-semibold">Superior</span>
                                    ; break;
                                case 3:

                                    <span class="badge bg-warning text-dark px-3 py-2 shadow-sm fs-7 fw-semibold">Suite</span>
                                    ; break;
                            }
                        </div>

                        <div class="card-body p-4 pt-5">
                            <h4 class="card-title fw-bold text-dark mb-1">@item.NombreDeHabitacion</h4>
                            <p class="text-muted fs-7 mb-3"><i class="bi bi-geo-alt-fill text-danger me-1"></i>Ubicación: @item.Ubicacion</p>

                            <div class="row g-2 border-top border-bottom py-3 my-3 text-secondary text-center fs-7 bg-light rounded-2">
                                <div class="col-4 border-end">
                                    <i class="bi bi-people-fill d-block mb-1 text-primary"></i>
                                    <strong>@item.CantidadDeHuespedesPermitidos</strong> Máx.
                                </div>
                                <div class="col-4 border-end">
                                    <i class="bi bi-door-closed-fill d-block mb-1 text-success"></i>
                                    <strong>@item.CantidadDeCamas</strong> Camas
                                </div>
                                <div class="col-4">
                                    <i class="bi bi-droplet-fill d-block mb-1 text-info"></i>
                                    <strong>@item.CantidadDeBanos</strong> Baños
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    <span class="fs-7 text-muted d-block">Costo por noche</span>
                                    <span class="fs-4 fw-bold text-success">₡@item.CostoDeReserva.ToString("N2")</span>
                                </div>
                                <div class="text-end">
                                    <span class="fs-7 text-muted d-block">Limpieza</span>
                                    <span class="fs-6 fw-semibold text-secondary">₡@item.CostoDeLimpieza.ToString("N2")</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <a asp-action="Reservar" asp-route-idHabitacion="@item.Id" class="btn btn-primary w-100 py-2 fw-medium shadow-sm">
                                <i class="bi bi-calendar-check me-2"></i>Reservar Ahora
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
