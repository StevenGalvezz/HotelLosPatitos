@model HotelLosPatitos.Domain.Entities.Habitacion

@{
    ViewData["Title"] = "Registrar Nueva Habitación";
}

<div class="container my-5" style="max-width: 800px;">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
            <i class="bi bi-arrow-left me-1"></i> Volver a la lista
        </a>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-primary text-white p-4">
            <h3 class="card-title mb-1 fw-bold"><i class="bi bi-door-open-fill me-2"></i>Nueva Habitación</h3>
            <p class="mb-0 text-white-50 fs-7">Complete todos los datos requeridos para habilitar las reservas.</p>
        </div>

        <div class="card-body p-4 bg-light">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-start border-4 border-danger rounded-3" role="alert"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="CodigoDeHabitacion" class="form-label fw-semibold text-secondary">Código</label>
                        <input asp-for="CodigoDeHabitacion" class="form-control" placeholder="Ej: J-101" maxlength="7" required />
                        <span asp-validation-for="CodigoDeHabitacion" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="NombreDeHabitacion" class="form-label fw-semibold text-secondary">Nombre de la Habitación</label>
                        <input asp-for="NombreDeHabitacion" class="form-control" placeholder="Ej: Junior Familiar Estandar" maxlength="30" required />
                        <span asp-validation-for="NombreDeHabitacion" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-5">
                        <label asp-for="Ubicacion" class="form-label fw-semibold text-secondary">Ubicación</label>
                        <input asp-for="Ubicacion" class="form-control" placeholder="Ej: Piso 1" maxlength="10" required />
                        <span asp-validation-for="Ubicacion" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-7">
                        <label asp-for="TipoDeHabitacion" class="form-label fw-semibold text-secondary">Tipo de Habitación</label>
                        <select asp-for="TipoDeHabitacion" class="form-select" required>
                            <option value="" disabled selected>-- Seleccione una opción --</option>
                            <option value="1">1 - Junior</option>
                            <option value="2">2 - Superior</option>
                            <option value="3">3 - Suite</option>
                        </select>
                        <span asp-validation-for="TipoDeHabitacion" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CantidadDeHuespedesPermitidos" class="form-label fw-semibold text-secondary">Máx. Huéspedes</label>
                        <input asp-for="CantidadDeHuespedesPermitidos" type="number" class="form-control" min="1" required />
                        <span asp-validation-for="CantidadDeHuespedesPermitidos" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CantidadDeCamas" class="form-label fw-semibold text-secondary">Cantidad de Camas</label>
                        <input asp-for="CantidadDeCamas" type="number" class="form-control" min="0" required />
                        <span asp-validation-for="CantidadDeCamas" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CantidadDeBanos" class="form-label fw-semibold text-secondary">Cantidad de Baños</label>
                        <input asp-for="CantidadDeBanos" type="number" class="form-control" min="0" required />
                        <span asp-validation-for="CantidadDeBanos" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-7">
                        <label asp-for="EncargadoDeLimpieza" class="form-label fw-semibold text-secondary">Encargado de Limpieza</label>
                        <input asp-for="EncargadoDeLimpieza" class="form-control" placeholder="Nombre completo del responsable" maxlength="100" required />
                        <span asp-validation-for="EncargadoDeLimpieza" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-5">
                        <label asp-for="CostoDeLimpieza" class="form-label fw-semibold text-secondary">Costo de Limpieza (₡)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">₡</span>
                            <input asp-for="CostoDeLimpieza" type="number" step="0.01" class="form-control" min="0.01" required />
                        </div>
                        <span asp-validation-for="CostoDeLimpieza" class="text-danger fs-7"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="CostoDeReserva" class="form-label fw-semibold text-secondary">Costo de Reserva por Día (₡)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">₡</span>
                            <input asp-for="CostoDeReserva" type="number" step="0.01" class="form-control" min="0.01" required />
                        </div>
                        <span asp-validation-for="CostoDeReserva" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    <button type="reset" class="btn btn-light border px-4">Limpiar</button>
                    <button type="submit" class="btn btn-primary px-5 shadow-sm fw-medium">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> Guardar Habitación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
