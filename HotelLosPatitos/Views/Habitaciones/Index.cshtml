@model IEnumerable<HotelLosPatitos.Domain.Entities.Habitacion>

@{
    ViewData["Title"] = "Administración de Habitaciones";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded shadow-sm border-start border-4 border-primary">
        <div>
            <h1 class="display-6 fw-bold text-dark mb-1">Módulo de Habitaciones</h1>
            <p class="text-muted mb-0">Administra las habitaciones, costos operativos y estados del hotel.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm px-4">
                <i class="bi bi-plus-circle me-2"></i>Registrar Habitación
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="bg-dark text-white text-uppercase fs-7">
                        <tr>
                            <th class="ps-4 py-3">Código</th>
                            <th>Nombre</th>
                            <th>Ubicación</th>
                            <th class="text-center">Huéspedes</th>
                            <th class="text-center">Camas</th>
                            <th class="text-center">Baños</th>
                            <th>Responsable Limpieza</th>
                            <th class="text-end">Costo Limpieza</th>
                            <th class="text-end">Costo Reserva</th>
                            <th>Tipo</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="12" class="text-center py-5 text-muted">
                                    <i class="bi bi-building-exclamation display-6 d-block mb-3"></i>
                                    No hay habitaciones registradas en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.CodigoDeHabitacion</td>
                                    <td class="fw-semibold">@item.NombreDeHabitacion</td>
                                    <td><span class="badge bg-light text-dark border">@item.Ubicacion</span></td>
                                    <td class="text-center">@item.CantidadDeHuespedesPermitidos</td>
                                    <td class="text-center">@item.CantidadDeCamas</td>
                                    <td class="text-center">@item.CantidadDeBanos</td>
                                    <td>@item.EncargadoDeLimpieza</td>
                                    <td class="text-end fw-semibold text-secondary">₡@item.CostoDeLimpieza.ToString("N2")</td>
                                    <td class="text-end fw-semibold text-success">₡@item.CostoDeReserva.ToString("N2")</td>
                                    <td>
                                        @switch (item.TipoDeHabitacion)
                                        {
                                            case 1:
                                                <span class="text-muted">Junior</span>
                                                ; break;
                                            case 2:

                                                <span class="text-info fw-medium">Superior</span>
                                                ; break;
                                            case 3:

                                                <span class="text-warning fw-medium">Suite</span>
                                                ; break;
                                            default:

                                                <span class="text-danger">Desconocido</span>
                                                ; break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.Estado)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill border border-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill border border-danger">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>
                                            <a asp-controller="ReservaAdministrativa" asp-action="Index" asp-route-idHabitacion="@item.Id" class="btn btn-outline-info" title="Ver reservas">
                                                <i class="bi bi-calendar3"></i> Reservas
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
