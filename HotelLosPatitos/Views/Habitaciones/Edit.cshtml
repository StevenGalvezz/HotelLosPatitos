@model HotelLosPatitos.Domain.Entities.Habitacion

@{
    ViewData["Title"] = "Editar Habitación";
}

<div class="container my-5" style="max-width: 800px;">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
            <i class="bi bi-arrow-left me-1"></i> Volver a la lista
        </a>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-warning text-dark p-4">
            <h3 class="card-title mb-1 fw-bold"><i class="bi bi-pencil-square me-2"></i>Modificar Habitación</h3>
            <p class="mb-0 text-dark-50 fs-7">Actualice los costos operativos o características de la habitación.</p>
        </div>

        <div class="card-body p-4 bg-light">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- Cuadrado rojo removido por completo -->

                <div class="row g-3">
                    <div class="col-12">
                        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center mb-2" role="alert">
                            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                            <div>Los campos de Código, Nombre y Ubicación no son editables por restricciones del negocio.</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold text-muted">Código</label>
                        <input asp-for="CodigoDeHabitacion" class="form-control bg-body-secondary text-muted" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Nombre de la Habitación</label>
                        <input asp-for="NombreDeHabitacion" class="form-control bg-body-secondary text-muted" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold text-muted">Ubicación</label>
                        <input asp-for="Ubicacion" class="form-control bg-body-secondary text-muted" readonly />
                    </div>

                    <hr class="my-4 text-secondary opacity-25">

                    <div class="col-md-5">
                        <label asp-for="TipoDeHabitacion" class="form-label fw-semibold text-secondary">Tipo de Habitación</label>
                        <select asp-for="TipoDeHabitacion" class="form-select" required>
                            <option value="1">1 - Junior</option>
                            <option value="2">2 - Superior</option>
                            <option value="3">3 - Suite</option>
                        </select>
                        <span asp-validation-for="TipoDeHabitacion" class="text-danger fs-7 d-block mt-1"></span>
                    </div>

                    <div class="col-md-7">
                        <label asp-for="EncargadoDeLimpieza" class="form-label fw-semibold text-secondary">Encargado de Limpieza</label>
                        <input asp-for="EncargadoDeLimpieza" class="form-control" maxlength="100" required />
                        <span asp-validation-for="EncargadoDeLimpieza" class="text-danger fs-7 d-block mt-1"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CantidadDeHuespedesPermitidos" class="form-label fw-semibold text-secondary">Máx. Huéspedes</label>
                        <input asp-for="CantidadDeHuespedesPermitidos" type="number" class="form-control" min="1" required />
                        <span asp-validation-for="CantidadDeHuespedesPermitidos" class="text-danger fs-7 d-block mt-1"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CantidadDeCamas" class="form-label fw-semibold text-secondary">Cantidad de Camas</label>
                        <input asp-for="CantidadDeCamas" type="number" class="form-control" min="0" required />
                        <span asp-validation-for="CantidadDeCamas" class="text-danger fs-7 d-block mt-1"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CostoDeLimpieza" class="form-label fw-semibold text-secondary">Costo Limpieza (₡)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">₡</span>
                            <input asp-for="CostoDeLimpieza" type="number" step="0.01" class="form-control" min="0.01" required />
                        </div>
                        <span asp-validation-for="CostoDeLimpieza" class="text-danger fs-7 d-block mt-1"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="CostoDeReserva" class="form-label fw-semibold text-secondary">Costo de Reserva por Día (₡)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">₡</span>
                            <input asp-for="CostoDeReserva" type="number" step="0.01" class="form-control" min="0.01" required />
                        </div>
                        <span asp-validation-for="CostoDeReserva" class="text-danger fs-7 d-block mt-1"></span>
                    </div>

                    <div class="col-md-4 d-flex align-items-end pb-2">
                        <div class="form-check form-switch card p-2 px-5 border shadow-sm bg-white mb-0 w-100">
                            <input class="form-check-input fs-5" type="checkbox" role="switch" id="switchEstado" asp-for="Estado">
                            <label class="form-check-label fw-bold text-dark ms-2 pt-1" for="switchEstado">Disponibilidad Activa</label>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    <a asp-action="Index" class="btn btn-light border px-4">Cancelar</a>
                    <button type="submit" class="btn btn-warning px-5 shadow-sm fw-medium">
                        <i class="bi bi-save-fill me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
