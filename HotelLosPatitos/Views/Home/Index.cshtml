@{
    ViewData["Title"] = "Inicio";
}

<div class="container my-5 py-4">
    <div class="text-center p-5 mb-5 bg-dark text-white rounded-3 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
        <div class="position-relative z-1">
            <i class="bi bi-water display-1 text-warning mb-3 d-block"></i>
            <h1 class="display-4 fw-bold">Bienvenido a Hotel Los Patitos</h1>
            <p class="col-lg-8 mx-auto fs-5 text-white-50">
                El sistema integrado de gestión hotelera y reservaciones en línea. Seleccione su portal de ingreso a continuación.
            </p>
        </div>
        
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-6 col-lg-5">
            <div class="card h-100 shadow border-0 rounded-3 card-hover bg-white overflow-hidden text-center p-4">
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div class="rounded-circle bg-success-subtle text-success p-4 mb-4 shadow-sm">
                        <i class="bi bi-calendar2-check-fill display-5"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">Portal de Huéspedes</h3>
                    <p class="text-muted fs-7 mb-4 px-3">
                        ¿Deseas hospedarte con nosotros? Consulta las habitaciones disponibles en tiempo real, calcula el costo total de tu estadía y realiza tu reservación de forma segura.
                    </p>
                    <a asp-controller="Reservas" asp-action="Index" class="btn btn-success btn-lg w-100 py-3 fw-bold mt-auto shadow-sm">
                        <i class="bi bi-door-open me-2"></i>Ver Disponibilidad
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-5">
            <div class="card h-100 shadow border-0 rounded-3 card-hover bg-white overflow-hidden text-center p-4">
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div class="rounded-circle bg-primary-subtle text-primary p-4 mb-4 shadow-sm">
                        <i class="bi bi-shield-lock-fill display-5"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">Módulo Administrativo</h3>
                    <p class="text-muted fs-7 mb-4 px-3">
                        Acceso exclusivo para colaboradores del hotel. Permite registrar nuevas habitaciones, modificar las tarifas operativas vigentes y auditar el historial completo de reservas de forma rápida.
                    </p>
                    <a asp-controller="Habitaciones" asp-action="Index" class="btn btn-primary btn-lg w-100 py-3 fw-bold mt-auto shadow-sm">
                        <i class="bi bi-gear-fill me-2"></i>Gestionar Hotel
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="text-center mt-5 pt-4 text-muted border-top opacity-75">
        <p class="mb-0 fs-7">
            <i class="bi bi-info-circle me-1"></i> Despachado bajo lineamientos de Arquitectura Limpia, Domain-Driven Design (DDD) y Principios SOLID.
        </p>
    </div>
</div>

<style>
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }
</style>
